{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "time",
          "style": "diamond",
          "background": "#b8bfc2",
          "foreground": "#ebdbb2",
          "leading_diamond": "",
          "trailing_diamond": "",
          "properties": {
            "time_format": "15:04:05"
          }
        },
        {
          "background": "#d3869b",
          "foreground": "#ebdbb2",
          "style": "powerline",
          "powerline_symbol": "",
          "type": "session"
        },
        {
          "background": "#83a598",
          "foreground": "#ebdbb2",
          "powerline_symbol": "",
          "properties": {
            "prefix": "  ",
            "style": "folder"
          },
          "style": "powerline",
          "type": "path"
        },
        {
          "background": "#fabd2f",
          "foreground": "#282828",
          "powerline_symbol": "",
          "properties": {
            "display_stash_count": true,
            "display_upstream_icon": true
          },
          "style": "powerline",
          "type": "git"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true
}
